---
import Icon from './Icon.astro';
interface Props { icon: string; title: string; text: string; href?: string }
const { icon, title, text, href } = Astro.props;
---
<article class="card service-card"><span class="icon-box"><Icon name={icon} /></span><h3>{title}</h3><p>{text}</p>{href && <a class="text-link" href={href}>Learn more <Icon name="arrow" size={17} /></a>}</article>
