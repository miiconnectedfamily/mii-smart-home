---
import Layout from '../layouts/Layout.astro'; import Hero from '../components/Hero.astro'; import PackageCard from '../components/PackageCard.astro'; import CTASection from '../components/CTASection.astro';
const packages=[
{title:'Smart Home Starter',text:'A friendly first step into home automation.',items:['Goals and compatibility review','Core platform setup','Help connecting starter devices','One practical routine','Security and aftercare guidance'],featured:true},
{title:'Smart Doorbell Setup',text:'Get your doorbell connected and configured properly.',items:['Device and app setup','Wi-Fi signal check','Motion and privacy zones','Notification tuning','Secure account guidance']},
{title:'Smart Camera Setup',text:'Make a smart camera useful from day one.',items:['Indoor or outdoor setup','Connection and app access','Recording option guidance','Activity and privacy zones','Notification tuning']},
{title:'Home Automation Review',text:'Make better use of the devices you already own.',items:['Existing device review','Compatibility check','Routine improvements','App and room organisation','Simple improvement plan']},
{title:'Small Business Camera Setup',text:'Practical smart camera help for a small office or shop.',items:['Needs and placement review','Camera and app setup','Notification configuration','Account access guidance','Clear handover']},
{title:'Wi-Fi & Smart Device Health Check',text:'Find out why connected devices are unreliable.',items:['Coverage and placement review','Connection checks','Update and security review','Practical recommendations','Prioritised improvement plan']}
];
---
<Layout title="Smart Home Setup Packages | MII Solutions" description="Flexible smart home packages for starters, doorbells, cameras, automation reviews, small businesses and Wi-Fi health checks. Contact us for a quote."><Hero compact eyebrow="Smart home packages" title="Clear starting points, tailored to your home" text="Choose the closest package and we will shape it around your devices, property and goals. Contact us for a quote—there is no one-size-fits-all price." /><section class="section"><div class="container"><div class="grid grid-3">{packages.map(item=><PackageCard {...item} />)}</div></div></section><section class="section section-soft"><div class="container split"><div><p class="eyebrow">How quoting works</p><h2>A fair quote starts with a clear picture</h2><p>Send us a short description, device links or photos of the product labels. We will confirm the likely scope and any important dependencies before quoting.</p></div><div class="card"><h3>Helpful details to share</h3><ul class="check-list"><li>What you want to achieve</li><li>Devices you already have</li><li>Your preferred voice assistant or app</li><li>Whether you need remote or London on-site help</li></ul></div></div></section><CTASection title="Which package sounds closest?" text="Message us with the package name and a little about your setup. We will take it from there." /></Layout>
