---
import Layout from '../layouts/Layout.astro'; import Hero from '../components/Hero.astro'; import BlogCard from '../components/BlogCard.astro'; import CTASection from '../components/CTASection.astro';
const guides=[
['Alexa vs Google Home: which is better for a beginner?','A plain-English comparison of setup, voice control and compatibility.','/guides/alexa-vs-google-home/'],['Ring vs Eufy vs Tapo: which video doorbell should you buy?','Compare storage, subscriptions and the everyday experience.','/guides/ring-vs-eufy-vs-tapo/'],['Smart camera privacy checklist','Important account, placement and app settings to review.','/guides/smart-camera-privacy-checklist/'],['Wi-Fi camera vs IP camera: simple explanation','Understand common camera terms without the jargon.'],['Do smart cameras need a subscription?','What subscriptions include and where local storage fits.'],['What is Matter in smart homes?','How the compatibility standard can help devices work together.'],['What is Thread in smart homes?','A simple look at the low-power network behind some devices.'],['Best smart home setup for elderly parents','Useful ideas designed around simplicity, comfort and confidence.'],['How to make lights turn on automatically at sunset','A practical first routine for smart home beginners.'],['Smart home security checklist for connected homes','The essential account, update and privacy basics.'],['How to avoid buying incompatible smart devices','Questions to ask before you press the buy button.'],['Local storage vs cloud storage for smart cameras','The trade-offs in access, cost and convenience.'],['Smart plugs: what can you safely use them for?','Suitable uses, device ratings and common-sense precautions.'],['Best smart home setup for renters','Portable ideas that do not require permanent changes.'],['How to improve Wi-Fi for smart cameras','Placement and coverage tips for a more reliable connection.']
];
---
<Layout title="Smart Home Guides for Beginners | MII Solutions" description="Simple smart home guides covering Alexa, Google Home, Ring, Eufy, Tapo, cameras, privacy, Wi-Fi, Matter, Thread, renters and elderly relatives."><Hero compact eyebrow="Blog & guides" title="Smart home questions, answered simply" text="Friendly, practical guides to help you choose devices, understand the options and get more from your setup—without the technical fog." /><section class="section"><div class="container"><div class="grid grid-3">{guides.map(([title,text,href])=><BlogCard title={title} text={text} href={href} />)}</div></div></section><CTASection title="Have a question we have not covered?" text="Send it to us on WhatsApp. It may become our next simple smart home guide." /></Layout>
