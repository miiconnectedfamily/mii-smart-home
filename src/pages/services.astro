---
import Layout from '../layouts/Layout.astro'; import Hero from '../components/Hero.astro'; import ServiceCard from '../components/ServiceCard.astro'; import CTASection from '../components/CTASection.astro'; import Icon from '../components/Icon.astro';
const services=[
['advice','Smart home consultation','Turn your goals, existing devices and budget into a clear, sensible plan.'],['home','Alexa & Google Home setup','Connect compatible devices, create rooms and make voice control easier to use.'],['bulb','Smart lighting setup','Set up bulbs, switches and scenes for convenient, everyday lighting.'],['plug','Smart plugs & appliance automation','Add schedules and routines to suitable household devices with safety in mind.'],['camera','Smart video doorbell installation','Position, connect and configure a smart doorbell with useful notifications.'],['camera','IP camera setup','Set up network-connected cameras with dependable app access and sensible privacy.'],['camera','Ring, Eufy & Tapo setup','Guidance and setup across popular camera and doorbell brands.'],['wifi','Wi-Fi improvement for smart devices','Identify weak coverage and improve the reliability of connected devices.'],['sensor','Sensors, motion & leak alerts','Set up practical alerts and triggers that can help protect your home.'],['routine','Basic automation routines','Create helpful routines for mornings, evenings, sunset, security and more.'],['business','Small business support','Camera and simple automation support for small offices and shops.'],['shield','Security & privacy basics','Account protection, updates, app permissions and privacy settings explained clearly.']
];
---
<Layout title="Smart Home Services & Worldwide Advice | MII Solutions" description="London-based smart home setup and beginner-friendly remote advice worldwide for Alexa, Google Home, lighting, cameras, doorbells, Wi-Fi, sensors and automation."><Hero compact eyebrow="Smart home services" title="Practical help for a home that works together" text="Choose one service or ask us to review the whole setup. We explain every step clearly and keep the solution appropriate for your home, budget and confidence level." /><section class="section"><div class="container"><div class="section-head"><div><p class="eyebrow">What we do</p><h2>Setup, advice and support</h2><p>Friendly help for beginners, families, landlords, renters and small businesses.</p></div></div><div class="grid grid-3">{services.map(([icon,title,text])=><ServiceCard icon={icon} title={title} text={text} />)}</div></div></section><section class="section section-soft"><div class="container split"><div><p class="eyebrow">Our approach</p><h2>Configured around people, not product boxes</h2><p>We begin with what you want to achieve. Then we look at compatibility, Wi-Fi, privacy and day-to-day usability before recommending the simplest route.</p></div><div class="feature-panel"><h3>Every setup includes clear guidance</h3><ul class="check-list"><li><Icon name="check" />What the device does—and does not do</li><li><Icon name="check" />How to keep its account and app secure</li><li><Icon name="check" />What to update and check over time</li><li><Icon name="check" />Where to find help after setup</li></ul></div></div></section><CTASection title="What would you like your home to do?" text="Tell us the result you want. We will help you find the most practical way to achieve it." /></Layout>
