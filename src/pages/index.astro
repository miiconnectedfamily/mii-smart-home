---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import TrustBadge from '../components/TrustBadge.astro';
import PackageCard from '../components/PackageCard.astro';
import FAQ from '../components/FAQ.astro';
import CTASection from '../components/CTASection.astro';
import Icon from '../components/Icon.astro';
const services = [
  {icon:'advice',title:'Smart home consultation',text:'A clear plan for the devices, budget and results that matter to you.',href:'/advice-before-you-buy/'},
  {icon:'camera',title:'Cameras & doorbells',text:'Reliable setup for Ring, Eufy and Tapo, with privacy and notifications configured.',href:'/smart-cameras-doorbells/'},
  {icon:'bulb',title:'Lighting & automation',text:'Smart lights, plugs, sensors and useful routines that make everyday life easier.',href:'/services/'},
  {icon:'wifi',title:'Wi-Fi for smart devices',text:'Improve coverage and reliability so devices stay connected where you need them.',href:'/services/'},
  {icon:'home',title:'Alexa & Google Home',text:'Simple voice control and device grouping, set up around your household.',href:'/services/'},
  {icon:'business',title:'Small business support',text:'Practical camera and automation help for small offices and shops.',href:'/services/'},
];
const faqs = [
  {question:'Can you help before I buy anything?',answer:'Yes. We can compare options, check compatibility and explain any ongoing subscriptions before you spend money.'},
  {question:'Do you offer remote advice?',answer:'Yes. Remote smart home advice is available worldwide. On-site availability is focused on London and depends on location.'},
  {question:'Can you make my existing devices work together?',answer:'Often, yes. We will review the brands, apps and platforms you already use, then recommend the simplest practical route.'},
  {question:'Will you help secure my smart devices?',answer:'Security and privacy are part of every setup. We cover strong account protection, updates, sensible permissions, privacy zones and secure app access.'},
];
---
<Layout title="MII Solutions | Smart Home Setup & Worldwide Advice" description="London-based smart home setup, camera and video doorbell installation, automation and Wi-Fi help, with remote smart home advice available worldwide.">
  <Hero eyebrow="Smart home help, without the jargon" title="Smart Home Solutions Made Simple" text="Affordable smart home setup, camera installation, automation and device advice for homes and small businesses. We help you choose, install and configure technology that actually works together." />
  <section class="section"><div class="container"><div class="section-head"><div><p class="eyebrow">How we can help</p><h2>Useful technology, set up properly</h2><p>From one doorbell to a connected home, we keep the process clear and practical.</p></div><a class="text-link" href="/services/">See all services <Icon name="arrow" size={18} /></a></div><div class="grid grid-3">{services.map(service => <ServiceCard {...service} />)}</div></div></section>
  <section class="section section-soft"><div class="container split"><div><p class="eyebrow">Ask before you buy</p><h2>Spend once. Choose well.</h2><p>Smart home products do not always work together as neatly as the box suggests. We help you compare ecosystems, storage options and subscriptions before you commit.</p><ul class="check-list"><li><Icon name="check" size={19} />Check that devices work with your phone and voice assistant</li><li><Icon name="check" size={19} />Understand subscriptions and local storage</li><li><Icon name="check" size={19} />Choose practical options for renters and elderly relatives</li></ul><a class="button button-secondary" href="/advice-before-you-buy/">Get buying advice</a></div><div class="feature-panel"><span class="icon-box"><Icon name="advice" size={26} /></span><h3>Not sure where to start?</h3><p>Send us the product link or describe what you want your home to do. We will help you spot compatibility problems and unnecessary costs.</p><p class="microcopy"><Icon name="message" size={17} /> A quick WhatsApp message can save an expensive mistake.</p></div></div></section>
  <section class="section"><div class="container split"><div class="feature-panel"><span class="icon-box"><Icon name="camera" size={27} /></span><h2>Clearer alerts. Better privacy. More reliable cameras.</h2><p>We configure the details that make a smart doorbell or camera genuinely useful: Wi-Fi reliability, activity zones, notifications, recording choices and secure accounts.</p><a class="button button-white" href="/smart-cameras-doorbells/">Explore camera help</a></div><div><p class="eyebrow">Smart cameras & doorbells</p><h2>See what matters—not every passing car</h2><p>A camera should give you confidence, not a stream of unhelpful alerts. We help with indoor and outdoor options from Ring, Eufy and Tapo.</p><div class="trust-grid"><TrustBadge icon="wifi" title="Reliable connection" text="Signal checks and practical placement advice." /><TrustBadge icon="shield" title="Privacy-aware" text="Secure accounts, privacy zones and sensible access." /><TrustBadge icon="camera" title="Useful alerts" text="Motion areas and notifications tuned for you." /><TrustBadge icon="advice" title="Storage explained" text="Cloud and local choices in plain English." /></div></div></div></section>
  <section class="section section-soft"><div class="container"><div class="section-head"><div><p class="eyebrow">Why MII Solutions</p><h2>IT experience, translated into everyday help</h2></div><a class="text-link" href="/why-choose-us/">Why choose us <Icon name="arrow" size={18} /></a></div><div class="trust-grid"><TrustBadge icon="business" title="Experienced IT engineer" text="A practical background in networks, Wi-Fi and connected devices." /><TrustBadge icon="shield" title="Microsoft & VMware certified" text="Professional technical foundations with cyber security awareness." /><TrustBadge icon="advice" title="Independent advice" text="Help before you buy, without unnecessary upselling." /><TrustBadge icon="message" title="No jargon" text="Patient explanations and clear aftercare guidance." /></div></div></section>
  <section class="section"><div class="container"><div class="section-head"><div><p class="eyebrow">Simple starting points</p><h2>Packages shaped around real needs</h2><p>Every home is different, so we quote after a quick conversation.</p></div><a class="text-link" href="/packages/">View all packages <Icon name="arrow" size={18} /></a></div><div class="grid grid-3"><PackageCard title="Smart Home Starter" text="Start small with a solid foundation." items={['Initial consultation','Platform and device setup','One useful routine','Security basics']} featured /><PackageCard title="Smart Doorbell Setup" text="A doorbell that alerts you at the right time." items={['Device and app setup','Wi-Fi signal check','Motion and privacy zones','Secure account guidance']} /><PackageCard title="Wi-Fi & Device Health Check" text="Improve unreliable smart devices." items={['Coverage review','Connection checks','Practical improvement plan','Device update guidance']} /></div></div></section>
  <section class="section section-soft"><div class="container split"><div><p class="eyebrow">Questions, answered</p><h2>A straightforward way to get started</h2><p>If your question is not here, send us a WhatsApp message. There is no need to know the technical terms.</p></div><FAQ items={faqs} /></div></section>
  <CTASection />
</Layout>
